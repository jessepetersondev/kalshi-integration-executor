{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Executor": {
    "ServiceName": "Kalshi.Integration.Executor",
    "Mode": "Worker"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest",
    "Exchange": "kalshi.integration.events",
    "ExchangeType": "topic",
    "ExecutorQueue": "kalshi.integration.executor",
    "ExecutorResultsQueue": "kalshi.integration.executor.results",
    "ExecutorDeadLetterQueue": "kalshi.integration.executor.dlq",
    "ExecutorResultsDeadLetterQueue": "kalshi.integration.executor.results.dlq",
    "RoutingKeyBinding": "kalshi.integration.trading.#",
    "ResultsRoutingKeyBinding": "kalshi.integration.results.#",
    "ClientProvidedName": "kalshi-integration-executor"
  },
  "Integrations": {
    "KalshiApi": {
      "Enabled": true,
      "BaseUrl": "https://api.elections.kalshi.com",
      "TimeoutSeconds": 10,
      "RetryAttempts": 2,
      "AccessKeyId": "",
      "AccessKeyIdEnvironmentVariable": "KALSHI_ACCESS_KEY_ID",
      "PrivateKeyPath": "",
      "PrivateKeyPem": "",
      "PrivateKeyPemEnvironmentVariable": "KALSHI_PRIVATE_KEY_PEM",
      "PrivateKeyPemBase64EnvironmentVariable": "KALSHI_PRIVATE_KEY_PEM_BASE64",
      "PrivateKeyPathEnvironmentVariable": "KALSHI_PRIVATE_KEY_PATH"
    }
  },
  "Persistence": {
    "ConnectionString": "Data Source=data/kalshi-integration-executor.db"
  },
  "RiskControls": {
    "LiveExecutionEnabled": true,
    "KillSwitchEnabled": false,
    "MaxOrderQuantity": 0,
    "MaxLimitPriceDollars": 0,
    "MaxOrderNotionalDollars": 0,
    "MaxDailyNotionalDollars": 0,
    "AllowedTickers": [],
    "AllowedTickerPrefixes": [],
    "DeniedTickers": []
  }
}
